# Triggerfish Docker environment overrides
# Copy this file to .env and uncomment the variables you need.
#
# API keys are typically set via `triggerfish config set-secret` (stored in
# the data volume), but you can also pass them as environment variables.

# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# BRAVE_API_KEY=BSA...
# ELEVENLABS_API_KEY=...

# Data directory inside the container (default: /data)
# TRIGGERFISH_DATA_DIR=/data

# Container image override (for local builds)
# TRIGGERFISH_IMAGE=triggerfish:dev

{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/v2/schemas/tauri.conf.json",
  "productName": "Triggerfish Tidepool",
  "identifier": "dev.triggerfish.tidepool",
  "version": "0.1.0",
  "build": {
    "frontendDist": "./frontend"
  },
  "app": {
    "windows": [
      {
        "title": "Triggerfish",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "visible": true
      }
    ],
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}

}

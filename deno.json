{
  "tasks": {
    "test": "deno test --allow-read --allow-write --allow-env --allow-ffi --allow-run --allow-net --allow-sys --no-check",
    "test:watch": "deno test --allow-read --allow-write --allow-env --allow-ffi --allow-run --allow-net --allow-sys --no-check --watch",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "check": "deno check src/mod.ts src/cli/main.ts",
    "dev": "deno run --allow-all src/mod.ts",
    "compile": "deno compile --allow-all --include config/ --include skills/ --include src/tidepool/tmpl_base.html --include src/tidepool/tmpl_styles.html --include src/tidepool/tmpl_chat.html --include src/tidepool/tmpl_canvas.html --include src/tidepool/tmpl_chat_script.html --include src/tidepool/tmpl_canvas_script.html --output=triggerfish src/cli/main.ts"
  },
  "compilerOptions": {
    "strict": true
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1",
    "@std/path": "jsr:@std/path@^1",
    "@std/yaml": "jsr:@std/yaml@^1",
    "@db/sqlite": "jsr:@db/sqlite@^0.13",
    "@anthropic-ai/sdk": "npm:@anthropic-ai/sdk@^0.39.0",
    "openai": "npm:openai@^4.28.0",
    "@google/generative-ai": "npm:@google/generative-ai@^0.21.0",
    "grammy": "npm:grammy@^1.20.0",
    "@slack/bolt": "npm:@slack/bolt@^3.17.0",
    "discord.js": "npm:discord.js@^14.14.0",
    "@cliffy/prompt": "jsr:@cliffy/prompt@^1.0.0-rc.7",
    "puppeteer-core": "npm:puppeteer-core@^24.0.0",
    "@mozilla/readability": "npm:@mozilla/readability@^0.5.0",
    "linkedom": "npm:linkedom@^0.18.0",
    "gpt-tokenizer": "npm:gpt-tokenizer@^2",
    "pyodide": "https://cdn.jsdelivr.net/pyodide/v0.27.0/full/pyodide.mjs"
  },
  "exclude": [
    "test-seeds/",
    ".claude/",
    "build-logs/"
  ]
}

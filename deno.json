{
  "tasks": {
    "test": "deno test --allow-read --allow-write --allow-env --allow-ffi --allow-run --allow-net=jsr.io,registry.npmjs.org --no-check",
    "test:watch": "deno test --allow-read --allow-write --allow-env --allow-ffi --allow-run --allow-net=jsr.io,registry.npmjs.org --no-check --watch",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "check": "deno check src/mod.ts",
    "dev": "deno run --allow-all src/mod.ts"
  },
  "compilerOptions": {
    "strict": true
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1",
    "@std/yaml": "jsr:@std/yaml@^1",
    "@db/sqlite": "jsr:@db/sqlite@^0.13"
  },
  "exclude": [
    "test-seeds/",
    ".claude/",
    "build-logs/"
  ]
}

{
  "tasks": {
    "test": "deno test --allow-read --allow-env",
    "test:watch": "deno test --allow-read --allow-env --watch",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "check": "deno check src/mod.ts",
    "dev": "deno run --allow-all src/mod.ts"
  },
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1"
  },
  "exclude": [
    "test-seeds/",
    ".claude/",
    "build-logs/"
  ]
}
